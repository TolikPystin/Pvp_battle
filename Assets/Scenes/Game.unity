  m_text: "\u041F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E \u043A\u0430\u043A
    \u0442\u044B \u0443\u0431\u0438\u043B 10 \u0432\u0440\u0430\u0433\u043E\u0432
    \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0439\u0441\u044F \u043A \u043C\u0435\u0441\u0442\u0443
    \u043F\u043E\u0434\u0431\u043E\u0440\u0430 \u043E\u0440\u0443\u0436\u0438\u044F
    \u0438 \u0442\u0430\u043C \u0431\u0443\u0434\u0435\u0442 \u043E\u0442\u043A\u0440\u044B\u0442\u0430
    \u0434\u0432\u0435\u0440\u044C, \u0442\u0435\u0431\u0435 \u0442\u0443\u0434\u0430.
    \u041F\u043E\u0442\u043E\u043C \u0431\u0443\u0434\u0443\u0442 \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0438\u0435
    \u043A\u043E\u043C\u043D\u0430\u0442\u044B, \u0442\u0430\u043C \u0431\u0443\u0434\u0443\u0442
    \u043A\u043D\u043E\u043F\u043A\u0438 \u0434\u043B\u044F \u0441\u043F\u0430\u0432\u043D\u0430
    \u0432\u0440\u0430\u0433\u043E\u0432, \u0442\u0435\u0431\u0435 \u0432 \u043A\u0430\u0436\u0434\u043E\u0439
    \u0438\u0437 \u043A\u043E\u043C\u043D\u0430\u0442 \u043D\u0443\u0436\u043D\u043E
    \u0431\u0443\u0434\u0435\u0442 \u0443\u0431\u0438\u0442\u044C \u043E\u0442 5
    \u0434\u043E 12 \u0432\u0440\u0430\u0433\u043E\u0432."
